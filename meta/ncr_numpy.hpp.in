 * SPDX-License-Identifier: MIT
 * SPDX-FileCopyrightText: 2023-2026 Nicolai Waniek <n@rochus.net>
 *
 * @ncr-fusor-import ../LICENSE strip_lines 2 5
 */

#define NCR_NUMPY_VERSION @ncr-fusor-import ../VERSION

